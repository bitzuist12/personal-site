---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'Ata Onat', description = 'Thoughts on history, culture, and startups.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav>
      <a href="/" class="nav-name">Ata Onat</a>
      <div class="nav-links">
        <a href="/writing">Writing</a>
        <a href="/projects">Projects</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} Ata Onat</p>
    </footer>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'EB Garamond', Georgia, serif;
    color: #1a1a1a;
    background: #faf9f7;
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 0;
    border-bottom: 1px solid #e5e3df;
    margin-bottom: 3rem;
  }

  .nav-name {
    font-size: 1.1rem;
    font-weight: 500;
    color: #1a1a1a;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: #666;
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .nav-links a:hover {
    color: #1a1a1a;
  }

  main {
    min-height: 60vh;
  }

  footer {
    margin-top: 4rem;
    padding: 2rem 0;
    border-top: 1px solid #e5e3df;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: #999;
  }

  h1 {
    font-size: 2rem;
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  h2 {
    font-size: 1.4rem;
    font-weight: 500;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  h3 {
    font-size: 1.15rem;
    font-weight: 500;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  p {
    margin-bottom: 1.2rem;
    font-size: 1.1rem;
  }

  a {
    color: #1a1a1a;
    text-decoration-color: #ccc;
    text-underline-offset: 3px;
  }

  a:hover {
    text-decoration-color: #1a1a1a;
  }

  .prose {
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .prose p {
    margin-bottom: 1.4rem;
  }

  .prose ul, .prose ol {
    margin-bottom: 1.4rem;
    padding-left: 1.5rem;
  }

  .prose li {
    margin-bottom: 0.4rem;
  }

  .prose blockquote {
    border-left: 2px solid #ddd;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #555;
    font-style: italic;
  }

  .date {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: #999;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    body {
      padding: 0 1rem;
    }

    nav {
      padding: 1.25rem 0;
      margin-bottom: 2rem;
    }

    h1 {
      font-size: 1.6rem;
    }

    h2 {
      font-size: 1.2rem;
    }

    h3 {
      font-size: 1.05rem;
    }

    p {
      font-size: 1rem;
    }

    .prose {
      font-size: 1rem;
    }
  }
</style>
